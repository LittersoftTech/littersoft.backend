{
  "info": {
    "name": "Pawfront Backend API",
    "description": "Complete API testing suite for the Pawfront provider-facing backend.\n\n**Setup**\n1. Set the `baseUrl` collection variable (default `https://localhost:5001`).\n2. Get a Firebase ID token (see CLAUDE.md `Get a fresh Firebase ID token`) and set `firebaseToken`.\n3. Run requests roughly in folder order. Several requests have test scripts that auto-populate ids (`providerAuthIdentityId`, `providerId`, `otpId`, `eventId`, `bookingId`).\n\n**Notes**\n- Every endpoint requires the `FirebaseUser` policy → `Authorization: Bearer {{firebaseToken}}`.\n- All responses follow the `ApiResponse<T>` envelope: `{ success, data, error }`.\n- A provider can register only ONE service category. Pick one of the five service folders and stick to it for a given `providerId`.\n- Image-upload requests use multipart with field name `file`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{firebaseToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001" },
    { "key": "firebaseToken", "value": "PASTE_FIREBASE_ID_TOKEN_HERE" },
    { "key": "providerAuthIdentityId", "value": "" },
    { "key": "providerId", "value": "" },
    { "key": "otpId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "petParentId", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/health", "host": ["{{baseUrl}}"], "path": ["api","v1","health"] }
          }
        }
      ]
    },
    {
      "name": "1. Provider Onboarding",
      "item": [
        {
          "name": "POST firebase-auth (upsert auth identity)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.providerAuthIdentityId) {",
                  "  pm.collectionVariables.set('providerAuthIdentityId', json.data.providerAuthIdentityId);",
                  "}",
                  "if (json && json.data && json.data.providerId) {",
                  "  pm.collectionVariables.set('providerId', json.data.providerId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/provider-onboarding/firebase-auth", "host": ["{{baseUrl}}"], "path": ["api","v1","provider-onboarding","firebase-auth"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcmToken\": \"fcm_dummy_token_abc123XYZ\",\n  \"deviceId\": \"device-uuid-9f1c-aa11-bb22\",\n  \"devicePlatform\": \"Android\"\n}"
            }
          }
        },
        {
          "name": "POST profile (complete provider profile)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.providerId) {",
                  "  pm.collectionVariables.set('providerId', json.data.providerId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/provider-onboarding/profile", "host": ["{{baseUrl}}"], "path": ["api","v1","provider-onboarding","profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerAuthIdentityId\": \"{{providerAuthIdentityId}}\",\n  \"firstName\": \"Ayur\",\n  \"lastName\": \"Shitarale\",\n  \"gender\": \"Male\",\n  \"mobileCountryCode\": \"+91\",\n  \"mobileNumber\": \"9876543210\",\n  \"dateOfBirth\": \"1995-08-22\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Mobile Verification",
      "item": [
        {
          "name": "POST send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.providerMobileOtpId) {",
                  "  pm.collectionVariables.set('otpId', json.data.providerMobileOtpId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/providers/{{providerId}}/mobile-verification/otp", "host": ["{{baseUrl}}"], "path": ["api","v1","providers","{{providerId}}","mobile-verification","otp"] }
          }
        },
        {
          "name": "POST verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/providers/{{providerId}}/mobile-verification/otp/{{otpId}}/verify", "host": ["{{baseUrl}}"], "path": ["api","v1","providers","{{providerId}}","mobile-verification","otp","{{otpId}}","verify"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otpCode\": \"123456\"\n}"
            }
          }
        }
      ]
    },
